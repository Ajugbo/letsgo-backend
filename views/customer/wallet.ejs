<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wallet - LetsGo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-white shadow-lg fixed w-full z-50">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <a href="/customer" class="text-2xl font-bold text-blue-600">
                <i class="fas fa-car-side mr-2"></i>LetsGo
            </a>
            <div class="flex items-center space-x-4">
                <a href="/customer/dashboard" class="text-gray-700 hover:text-blue-600">Dashboard</a>
                <a href="/customer/rides" class="text-gray-700 hover:text-blue-600">My Rides</a>
                <a href="/customer/logout" class="text-red-600">Logout</a>
            </div>
        </div>
    </nav>

    <div class="max-w-4xl mx-auto px-4 py-24">
        <h1 class="text-3xl font-bold text-gray-800 mb-8">💳 My Wallet</h1>

        <!-- Success/Error Messages -->
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                <%= success %>
            </div>
        <% } %>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                <%= error %>
            </div>
        <% } %>

        <!-- Balance Card -->
        <div class="bg-gradient-to-r from-purple-600 to-blue-600 rounded-2xl shadow-xl p-8 text-white mb-8">
            <p class="text-purple-200 mb-2">Current Balance</p>
            <p class="text-5xl font-bold">₦<%= parseFloat(wallet.balance || 0).toFixed(2) %></p>
            <p class="text-purple-200 mt-4"><i class="fas fa-shield-check mr-2"></i>Secure & Protected</p>
        </div>

        <!-- Fund Wallet -->
        <div class="bg-white rounded-2xl shadow-xl p-8 mb-8">
            <h2 class="text-2xl font-bold text-gray-800 mb-6">
                <i class="fas fa-plus-circle mr-2"></i>Fund Wallet
            </h2>

            <form action="/customer/wallet/fund" method="POST" class="space-y-4">
                <div>
                    <label class="block text-gray-700 font-semibold mb-2">Amount (₦)</label>
                    <input type="number" name="amount" min="1000" step="1000" placeholder="Minimum ₦1,000" required
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                </div>

                <button type="submit" class="w-full bg-blue-600 text-white py-4 rounded-lg font-bold text-lg hover:bg-blue-700 transition">
                    <i class="fas fa-wallet mr-2"></i>Pay with Paystack
                </button>
                
                <p class="text-sm text-gray-500 text-center mt-2">
                    <i class="fas fa-lock mr-1"></i>Secured by Paystack
                </p>
            </form>
        </div>

        <!-- Transaction History -->
        <div class="bg-white rounded-2xl shadow-xl p-8">
            <h2 class="text-2xl font-bold text-gray-800 mb-6">
                <i class="fas fa-history mr-2"></i>Transaction History
            </h2>

            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b bg-gray-50">
                            <th class="text-left py-3 px-4 font-semibold text-gray-700">Date</th>
                            <th class="text-left py-3 px-4 font-semibold text-gray-700">Description</th>
                            <th class="text-left py-3 px-4 font-semibold text-gray-700">Type</th>
                            <th class="text-left py-3 px-4 font-semibold text-gray-700">Amount</th>
                            <th class="text-left py-3 px-4 font-semibold text-gray-700">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (transactions && transactions.length > 0) { %>
                            <% transactions.forEach(txn => { %>
                                <tr class="border-b hover:bg-gray-50">
                                    <td class="py-3 px-4"><%= new Date(txn.created_at).toLocaleDateString() %></td>
                                    <td class="py-3 px-4"><%= txn.description || 'Wallet transaction' %></td>
                                    <td class="py-3 px-4">
                                        <span class="<%= txn.type === 'credit' ? 'text-green-600' : 'text-red-600' %>">
                                            <%= txn.type === 'credit' ? '💰 Credit' : '💸 Debit' %>
                                        </span>
                                    </td>
                                    <td class="py-3 px-4 font-semibold">₦<%= parseFloat(txn.amount).toFixed(2) %></td>
                                    <td class="py-3 px-4">
                                        <span class="px-2 py-1 rounded text-sm <%= 
                                            txn.status === 'success' ? 'bg-green-100 text-green-800' : 
                                            txn.status === 'failed' ? 'bg-red-100 text-red-800' : 
                                            'bg-yellow-100 text-yellow-800' 
                                        %>">
                                            <%= txn.status %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="py-4 text-center text-gray-500">No transactions yet. Fund your wallet to get started!</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
