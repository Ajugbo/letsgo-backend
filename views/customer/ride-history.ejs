<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ride History - LetsGo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50">
    <nav class="bg-white shadow-lg fixed w-full z-50">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <a href="/customer" class="text-2xl font-bold text-blue-600">
                <i class="fas fa-car-side mr-2"></i>LetsGo
            </a>
            <div class="flex items-center space-x-4">
                <a href="/customer/dashboard" class="text-gray-700 hover:text-blue-600">Dashboard</a>
                <a href="/customer/wallet" class="text-gray-700 hover:text-blue-600">Wallet</a>
                <a href="/customer/rides" class="text-blue-600 font-bold">Rides</a>
                <a href="/customer/logout" class="text-red-600">Logout</a>
            </div>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto px-4 py-24">
        <h1 class="text-3xl font-bold text-gray-800 mb-8">🚗 My Ride History</h1>

        <% if (rides && rides.length > 0) { %>
            <div class="space-y-4">
                <% rides.forEach(ride => { %>
                    <div class="bg-white rounded-xl shadow-lg p-6">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <p class="text-sm text-gray-500"><%= new Date(ride.created_at).toLocaleDateString() %></p>
                                <h3 class="text-lg font-bold text-gray-800 mt-2">
                                    <i class="fas fa-map-marker-alt text-green-500 mr-2"></i><%= ride.pickup_location %>
                                </h3>
                                <p class="text-gray-600">
                                    <i class="fas fa-map-marker-alt text-red-500 mr-2"></i><%= ride.dropoff_location %>
                                </p>
                                
                                <!-- Driver Info (Show when ride is accepted or completed) -->
                                <% if (ride.driver_name) { %>
                                    <div class="mt-3 p-3 bg-blue-50 rounded-lg">
                                        <p class="text-sm font-bold text-blue-800 mb-2">
                                            <i class="fas fa-user-circle mr-2"></i>Your Driver
                                        </p>
                                        <div class="grid grid-cols-2 gap-2 text-sm text-gray-700">
                                            <p><i class="fas fa-user mr-2"></i><%= ride.driver_name %></p>
                                            <p><i class="fas fa-phone mr-2"></i><%= ride.driver_phone %></p>
                                            <p><i class="fas fa-car mr-2"></i><%= ride.vehicle_model %> (<%= ride.vehicle_color %>)</p>
                                            <p><i class="fas fa-id-card mr-2"></i><%= ride.license_plate %></p>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                            <div class="text-right">
                                <p class="text-2xl font-bold text-blue-600">₦<%= parseFloat(ride.fare || 0).toFixed(2) %></p>
                                <span class="px-3 py-1 rounded-full text-sm <%= 
                                    ride.status === 'completed' ? 'bg-green-100 text-green-800' :
                                    ride.status === 'paid' ? 'bg-blue-100 text-blue-800' :
                                    ride.status === 'accepted' ? 'bg-purple-100 text-purple-800' :
                                    'bg-yellow-100 text-yellow-800'
                                %>">
                                    <%= ride.status %>
                                </span>
                            </div>
                        </div>
                        
                        <!-- Rating Section (Show for completed rides) -->
                        <% if (ride.status === 'completed' || ride.status === 'paid') { %>
                            <div class="mt-4 pt-4 border-t">
                                <% if (ride.rating) { %>
                                    <div class="flex items-center text-yellow-500">
                                        <i class="fas fa-star mr-1"></i>
                                        <span class="text-gray-700 ml-2">You rated this ride: <%= ride.rating %>/5</span>
                                    </div>
                                    <% if (ride.review) { %>
                                        <p class="text-sm text-gray-600 mt-2"><%= ride.review %></p>
                                    <% } %>
                                <% } else { %>
                                    <form action="/customer/ride/rate" method="POST" class="flex items-center space-x-2">
                                        <input type="hidden" name="ride_id" value="<%= ride.id %>">
                                        <select name="rating" required class="border rounded-lg px-3 py-2">
                                            <option value="">Rate...</option>
                                            <option value="5">⭐⭐⭐⭐⭐</option>
                                            <option value="4">⭐⭐⭐⭐</option>
                                            <option value="3">⭐⭐⭐</option>
                                            <option value="2">⭐⭐</option>
                                            <option value="1">⭐</option>
                                        </select>
                                        <input type="text" name="review" placeholder="Optional review..." class="border rounded-lg px-3 py-2 flex-1">
                                        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
                                            Submit
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        <% } %>
                        
                        <!-- Pay from Wallet (Show for completed unpaid rides) -->
                        <% if (ride.status === 'completed' && ride.payment_method === 'cash') { %>
                            <div class="mt-4 pt-4 border-t">
                                <form action="/customer/ride/pay" method="POST" class="flex items-center space-x-2">
                                    <input type="hidden" name="ride_id" value="<%= ride.id %>">
                                    <input type="hidden" name="amount" value="<%= ride.fare %>">
                                    <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700">
                                        <i class="fas fa-wallet mr-2"></i>Pay from Wallet
                                    </button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="bg-white rounded-xl shadow-lg p-12 text-center">
                <i class="fas fa-car text-6xl text-gray-300 mb-4"></i>
                <h2 class="text-2xl font-bold text-gray-800 mb-2">No Rides Yet</h2>
                <p class="text-gray-600 mb-6">Book your first ride to see it here!</p>
                <a href="/customer/book-ride" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700">
                    <i class="fas fa-car mr-2"></i>Book a Ride
                </a>
            </div>
        <% } %>
    </div>
</body>
</html>