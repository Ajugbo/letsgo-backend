<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book a Ride - LetsGo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-white shadow-lg fixed w-full z-50">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <a href="/customer" class="text-2xl font-bold text-blue-600">
                <i class="fas fa-car-side mr-2"></i>LetsGo
            </a>
            <div class="flex items-center space-x-4">
                <a href="/customer/dashboard" class="text-gray-700 hover:text-blue-600">Dashboard</a>
                <a href="/customer/wallet" class="text-gray-700 hover:text-blue-600">Wallet</a>
                <a href="/customer/rides" class="text-gray-700 hover:text-blue-600">My Rides</a>
                <a href="/customer/logout" class="text-red-600">Logout</a>
            </div>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto px-4 py-24">
        <h1 class="text-3xl font-bold text-gray-800 mb-8">🚗 Book Your Ride</h1>

        <!-- Success/Error Messages -->
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                <%= success %>
            </div>
        <% } %>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                <%= error %>
            </div>
        <% } %>

        <div class="grid md:grid-cols-2 gap-8">
            <!-- Booking Form -->
            <div class="bg-white rounded-2xl shadow-xl p-8">
                <h2 class="text-2xl font-bold text-gray-800 mb-6">
                    <i class="fas fa-map-marker-alt mr-2"></i>Ride Details
                </h2>

                <form action="/customer/ride/book" method="POST" class="space-y-4">
                    <!-- Pickup Location -->
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2">
                            <i class="fas fa-circle text-green-500 mr-2"></i>Pickup Location
                        </label>
                        <input type="text" name="pickup_location" id="pickup" 
                            placeholder="Enter pickup address" required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                    </div>

                    <!-- Dropoff Location -->
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2">
                            <i class="fas fa-circle text-red-500 mr-2"></i>Dropoff Location
                        </label>
                        <input type="text" name="dropoff_location" id="dropoff" 
                            placeholder="Enter dropoff address" required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                    </div>

                    <!-- Ride Type -->
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2">
                            <i class="fas fa-car mr-2"></i>Ride Type
                        </label>
                        <select name="ride_type" id="rideType" 
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                            <option value="economy">Economy (₦100/km)</option>
                            <option value="comfort">Comfort (₦150/km)</option>
                            <option value="premium">Premium (₦250/km)</option>
                        </select>
                    </div>

                    <!-- Seats -->
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2">
                            <i class="fas fa-users mr-2"></i>Number of Seats
                        </label>
                        <select name="seats" id="seats" 
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                            <option value="1">1 Passenger</option>
                            <option value="2">2 Passengers</option>
                            <option value="3">3 Passengers</option>
                            <option value="4">4 Passengers</option>
                        </select>
                    </div>

                    <!-- Estimated Fare -->
                    <div class="bg-blue-50 rounded-lg p-4">
                        <p class="text-gray-700 font-semibold mb-2">Estimated Fare:</p>
                        <p class="text-3xl font-bold text-blue-600">₦<span id="estimatedFare">0</span></p>
                        <p class="text-sm text-gray-500 mt-1">*Final fare may vary based on traffic</p>
                    </div>

                    <!-- Payment Method -->
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2">
                            <i class="fas fa-credit-card mr-2"></i>Payment Method
                        </label>
                        <select name="payment_method" 
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                            <option value="wallet">Wallet Balance</option>
                            <option value="cash">Cash on Delivery</option>
                        </select>
                    </div>

                    <button type="submit" class="w-full bg-blue-600 text-white py-4 rounded-lg font-bold text-lg hover:bg-blue-700 transition">
                        <i class="fas fa-car mr-2"></i>Request Ride
                    </button>
                </form>
            </div>

            <!-- Map -->
            <div class="bg-white rounded-2xl shadow-xl p-4">
                <div id="map" class="h-[600px] rounded-lg"></div>
            </div>
        </div>
    </div>

    <script>
        // Initialize Map (Abuja)
        const map = L.map('map').setView([9.0765, 7.3986], 12);
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        // Markers
        let pickupMarker = null;
        let dropoffMarker = null;

        // Click on map to set locations
        map.on('click', function(e) {
            if (!pickupMarker) {
                pickupMarker = L.marker(e.latlng).addTo(map)
                    .bindPopup('Pickup Location').openPopup();
                document.getElementById('pickup').value = `${e.latlng.lat.toFixed(4)}, ${e.latlng.lng.toFixed(4)}`;
            } else if (!dropoffMarker) {
                dropoffMarker = L.marker(e.latlng).addTo(map)
                    .bindPopup('Dropoff Location').openPopup();
                document.getElementById('dropoff').value = `${e.latlng.lat.toFixed(4)}, ${e.latlng.lng.toFixed(4)}`;
            } else {
                // Reset markers
                map.removeLayer(pickupMarker);
                map.removeLayer(dropoffMarker);
                pickupMarker = L.marker(e.latlng).addTo(map)
                    .bindPopup('Pickup Location').openPopup();
                dropoffMarker = null;
                document.getElementById('pickup').value = `${e.latlng.lat.toFixed(4)}, ${e.latlng.lng.toFixed(4)}`;
                document.getElementById('dropoff').value = '';
            }
        });

        // Fare Calculation (Simple: ₦100-250 per km based on ride type)
        const rideTypeRates = {
            economy: 100,
            comfort: 150,
            premium: 250
        };

        // Simple distance calculation (Haversine formula)
        function calculateDistance(lat1, lon1, lat2, lon2) {
            const R = 6371; // Earth's radius in km
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                      Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                      Math.sin(dLon/2) * Math.sin(dLon/2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
            return R * c;
        }

        // Update fare estimate
        function updateFare() {
            const pickup = document.getElementById('pickup').value;
            const dropoff = document.getElementById('dropoff').value;
            const rideType = document.getElementById('rideType').value;
            const seats = parseInt(document.getElementById('seats').value);

            if (pickup && dropoff) {
                const [lat1, lon1] = pickup.split(',').map(Number);
                const [lat2, lon2] = dropoff.split(',').map(Number);
                
                if (!isNaN(lat1) && !isNaN(lat2)) {
                    const distance = calculateDistance(lat1, lon1, lat2, lon2);
                    const baseFare = distance * rideTypeRates[rideType];
                    const totalFare = baseFare + (seats > 1 ? (seats - 1) * 500 : 0);
                    document.getElementById('estimatedFare').textContent = Math.round(totalFare).toLocaleString();
                }
            }
        }

        // Listen for changes
        document.getElementById('pickup').addEventListener('change', updateFare);
        document.getElementById('dropoff').addEventListener('change', updateFare);
        document.getElementById('rideType').addEventListener('change', updateFare);
        document.getElementById('seats').addEventListener('change', updateFare);
    </script>
</body>
</html>
