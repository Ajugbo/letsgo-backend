<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driver Wallet - LetsGo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50">
    <nav class="bg-white shadow-lg fixed w-full z-50">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <a href="/driver" class="text-2xl font-bold text-blue-600">
                <i class="fas fa-car-side mr-2"></i>LetsGo Driver
            </a>
            <div class="flex items-center space-x-4">
                <a href="/driver/dashboard" class="text-gray-700 hover:text-blue-600">Dashboard</a>
                <a href="/driver/rides" class="text-gray-700 hover:text-blue-600">Available</a>
                <a href="/driver/rides-history" class="text-gray-700 hover:text-blue-600">History</a>
                <a href="/driver/wallet" class="text-blue-600 font-bold">Wallet</a>
                <a href="/driver/logout" class="text-red-600">Logout</a>
            </div>
        </div>
    </nav>

    <div class="max-w-4xl mx-auto px-4 py-24">
        <h1 class="text-3xl font-bold text-gray-800 mb-8">💰 My Earnings</h1>

        <% if (locals.success) { %>
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                <i class="fas fa-check-circle mr-2"></i><%= success %>
            </div>
        <% } %>

        <% if (locals.error) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                <i class="fas fa-exclamation-circle mr-2"></i><%= error %>
            </div>
        <% } %>

        <div class="bg-gradient-to-r from-blue-600 to-blue-700 rounded-xl shadow-lg p-8 mb-8 text-white">
            <p class="text-blue-100 text-sm">Total Earnings</p>
            <h2 class="text-4xl font-bold">₦<%= parseFloat(earnings || 0).toFixed(2) %></h2>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
            <h3 class="text-xl font-bold text-gray-800 mb-4">Request Withdrawal</h3>
            <form action="/driver/withdraw" method="POST" class="space-y-4">
                <div>
                    <label class="block text-gray-700 font-bold mb-2">Amount (₦)</label>
                    <input type="number" name="amount" required min="1000" class="w-full border rounded-lg px-4 py-2">
                </div>
                <div>
                    <label class="block text-gray-700 font-bold mb-2">Bank Name</label>
                    <input type="text" name="bank_name" required placeholder="e.g., GTBank" class="w-full border rounded-lg px-4 py-2">
                </div>
                <div>
                    <label class="block text-gray-700 font-bold mb-2">Account Number</label>
                    <input type="text" name="account_number" required maxlength="10" class="w-full border rounded-lg px-4 py-2">
                </div>
                <div>
                    <label class="block text-gray-700 font-bold mb-2">Account Name</label>
                    <input type="text" name="account_name" required class="w-full border rounded-lg px-4 py-2">
                </div>
                <button type="submit" class="w-full bg-blue-600 text-white font-bold py-3 rounded-lg hover:bg-blue-700">Request Withdrawal</button>
            </form>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-8">
            <h3 class="text-xl font-bold text-gray-800 mb-4">Withdrawal History</h3>
            <% if (withdrawals && withdrawals.length > 0) { %>
                <div class="space-y-3">
                    <% withdrawals.forEach(w => { %>
                        <div class="border rounded-lg p-4 flex justify-between items-center">
                            <div>
                                <p class="font-bold">₦<%= parseFloat(w.amount).toFixed(2) %></p>
                                <p class="text-sm text-gray-600"><%= w.bank_name %> - <%= w.account_number %></p>
                            </div>
                            <span class="px-3 py-1 rounded-full text-sm <%= w.status === 'approved' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                                <%= w.status %>
                            </span>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="text-gray-600 text-center">No withdrawal requests yet.</p>
            <% } %>
        </div>
    </div>
</body>
</html>