<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Available Rides - LetsGo Driver</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50">
    <nav class="bg-white shadow-lg fixed w-full z-50">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <a href="/driver" class="text-2xl font-bold text-blue-600">
                <i class="fas fa-car-side mr-2"></i>LetsGo Driver
            </a>
            <div class="flex items-center space-x-4">
                <a href="/driver/dashboard" class="text-gray-700 hover:text-blue-600">Dashboard</a>
                <a href="/driver/rides" class="text-blue-600 font-bold">Rides</a>
                <a href="/driver/logout" class="text-red-600">Logout</a>
            </div>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto px-4 py-24">
        <h1 class="text-3xl font-bold text-gray-800 mb-8">🚗 Available Rides</h1>

        <!-- Success/Error Messages (Fixed - using locals instead of req.query) -->
        <% if (locals.success) { %>
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                <i class="fas fa-check-circle mr-2"></i><%= success %>
            </div>
        <% } %>

        <% if (locals.error) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                <i class="fas fa-exclamation-circle mr-2"></i><%= error %>
            </div>
        <% } %>

        <% if (rides && rides.length > 0) { %>
            <div class="space-y-4">
                <% rides.forEach(ride => { %>
                    <div class="bg-white rounded-xl shadow-lg p-6">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <p class="text-sm text-gray-500"><%= new Date(ride.created_at).toLocaleString() %></p>
                                <h3 class="text-lg font-bold text-gray-800 mt-2">
                                    <i class="fas fa-map-marker-alt text-green-500 mr-2"></i><%= ride.pickup_location %>
                                </h3>
                                <p class="text-gray-600">
                                    <i class="fas fa-map-marker-alt text-red-500 mr-2"></i><%= ride.dropoff_location %>
                                </p>
                                <div class="mt-2 text-sm text-gray-600">
                                    <p><i class="fas fa-user mr-2"></i>Customer: <%= ride.full_name %></p>
                                    <p><i class="fas fa-phone mr-2"></i>Phone: <%= ride.phone %></p>
                                    <p><i class="fas fa-car mr-2"></i>Type: <%= ride.ride_type %></p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="text-2xl font-bold text-blue-600">₦<%= parseFloat(ride.fare || 0).toFixed(2) %></p>
                                <span class="px-3 py-1 rounded-full text-sm bg-yellow-100 text-yellow-800">
                                    <%= ride.status %>
                                </span>
                            </div>
                        </div>
                        
                        <!-- Accept/Decline Buttons -->
                        <div class="flex space-x-2 mt-4 pt-4 border-t">
                            <form action="/driver/ride/accept" method="POST" class="flex-1">
                                <input type="hidden" name="ride_id" value="<%= ride.id %>">
                                <button type="submit" class="w-full bg-green-600 text-white py-2 rounded-lg hover:bg-green-700">
                                    <i class="fas fa-check mr-2"></i>Accept
                                </button>
                            </form>
                            <form action="/driver/ride/decline" method="POST" class="flex-1">
                                <input type="hidden" name="ride_id" value="<%= ride.id %>">
                                <button type="submit" class="w-full bg-red-600 text-white py-2 rounded-lg hover:bg-red-700">
                                    <i class="fas fa-times mr-2"></i>Decline
                                </button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="bg-white rounded-xl shadow-lg p-12 text-center">
                <i class="fas fa-car text-6xl text-gray-300 mb-4"></i>
                <h2 class="text-2xl font-bold text-gray-800 mb-2">No Available Rides</h2>
                <p class="text-gray-600">Check back later for new ride requests!</p>
            </div>
        <% } %>
    </div>
</body>
</html>