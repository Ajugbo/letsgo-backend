<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Withdrawal Requests - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50">
    <nav class="bg-white shadow-lg fixed w-full z-50">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <a href="/admin" class="text-2xl font-bold text-blue-600">
                <i class="fas fa-shield-alt mr-2"></i>LetsGo Admin
            </a>
            <div class="flex items-center space-x-4">
                <a href="/admin" class="text-gray-700 hover:text-blue-600">Dashboard</a>
                <a href="/admin/users" class="text-gray-700 hover:text-blue-600">Users</a>
                <a href="/admin/drivers" class="text-gray-700 hover:text-blue-600">Drivers</a>
                <a href="/admin/withdrawals" class="text-blue-600 font-bold">Withdrawals</a>
                <a href="/admin/rides" class="text-gray-700 hover:text-blue-600">Rides</a>
                <a href="/admin/wallets" class="text-gray-700 hover:text-blue-600">Wallets</a>
                <a href="/admin/logout" class="text-red-600">Logout</a>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 py-24">
        <h1 class="text-3xl font-bold text-gray-800 mb-8">💰 Withdrawal Requests</h1>

        <% if (locals.success) { %>
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                <i class="fas fa-check-circle mr-2"></i><%= success %>
            </div>
        <% } %>

        <% if (locals.error) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                <i class="fas fa-exclamation-circle mr-2"></i><%= error %>
            </div>
        <% } %>

        <% if (withdrawals && withdrawals.length > 0) { %>
            <div class="space-y-4">
                <% withdrawals.forEach(w => { %>
                    <div class="bg-white rounded-xl shadow-lg p-6">
                        <div class="flex justify-between items-start">
                            <div class="flex-1">
                                <div class="flex items-center mb-2">
                                    <h3 class="text-xl font-bold text-gray-800"><%= w.full_name %></h3>
                                    <span class="ml-3 px-3 py-1 rounded-full text-sm <%= 
                                        w.status === 'approved' ? 'bg-green-100 text-green-800' :
                                        w.status === 'rejected' ? 'bg-red-100 text-red-800' :
                                        'bg-yellow-100 text-yellow-800'
                                    %>">
                                        <%= w.status %>
                                    </span>
                                </div>
                                
                                <div class="grid grid-cols-2 gap-4 text-sm text-gray-600 mb-4">
                                    <p><i class="fas fa-phone mr-2"></i><%= w.phone %></p>
                                    <p><i class="fas fa-money-bill mr-2"></i>Amount: ₦<%= parseFloat(w.amount).toFixed(2) %></p>
                                    <p><i class="fas fa-university mr-2"></i>Bank: <%= w.bank_name %></p>
                                    <p><i class="fas fa-id-card mr-2"></i>Account: <%= w.account_number %></p>
                                    <p><i class="fas fa-user mr-2"></i>Account Name: <%= w.account_name %></p>
                                    <p><i class="fas fa-clock mr-2"></i>Requested: <%= new Date(w.created_at).toLocaleString() %></p>
                                </div>
                            </div>

                            <div class="text-green-600 font-bold">
                                <i class="fas fa-check-circle mr-2"></i>Auto-Approved
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="bg-white rounded-xl shadow-lg p-12 text-center">
                <i class="fas fa-money-bill-wave text-6xl text-gray-300 mb-4"></i>
                <h2 class="text-2xl font-bold text-gray-800 mb-2">No Withdrawal Requests</h2>
                <p class="text-gray-600">No driver withdrawal requests yet.</p>
            </div>
        <% } %>
    </div>
</body>
</html>