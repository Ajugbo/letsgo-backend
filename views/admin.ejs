<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LetsGo Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-100">
    <div class="min-h-screen">
        <div class="flex">
            <!-- Sidebar -->
            <div class="w-64 bg-gray-900 min-h-screen p-6">
                <h1 class="text-white text-2xl font-bold mb-8">LetsGo Admin</h1>
                <nav class="space-y-4">
                    <a href="/admin" class="text-white block py-2 px-4 rounded bg-blue-600">
                        <i class="fas fa-home mr-2"></i> Dashboard
                    </a>
                    <a href="/admin/users" class="text-gray-300 hover:bg-gray-800 block py-2 px-4 rounded">
                        <i class="fas fa-users mr-2"></i> Users
                    </a>
                    <a href="/admin/drivers" class="text-gray-300 hover:bg-gray-800 block py-2 px-4 rounded">
                        <i class="fas fa-id-card mr-2"></i> Drivers
                    </a>
                    <a href="/admin/rides" class="text-gray-300 hover:bg-gray-800 block py-2 px-4 rounded">
                        <i class="fas fa-car mr-2"></i> Rides
                    </a>
                    <a href="/admin/wallets" class="text-gray-300 hover:bg-gray-800 block py-2 px-4 rounded">
                        <i class="fas fa-wallet mr-2"></i> Wallets
                    </a>
                    <a href="/admin/logout" class="text-red-300 hover:bg-gray-800 block py-2 px-4 rounded">
                        <i class="fas fa-sign-out-alt mr-2"></i> Logout
                    </a>
                </nav>
            </div>

            <!-- Main Content -->
            <div class="flex-1 p-8">
                <h2 class="text-3xl font-bold text-gray-800 mb-6">Admin Dashboard</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    <div class="bg-white rounded-lg shadow p-6">
                        <p class="text-gray-500 text-sm">Total Users</p>
                        <p class="text-3xl font-bold text-blue-600"><%= stats.totalUsers || 0 %></p>
                    </div>
                    <div class="bg-white rounded-lg shadow p-6">
                        <p class="text-gray-500 text-sm">Total Rides</p>
                        <p class="text-3xl font-bold text-green-600"><%= stats.totalRides || 0 %></p>
                    </div>
                    <div class="bg-white rounded-lg shadow p-6">
                        <p class="text-gray-500 text-sm">Active Wallets</p>
                        <p class="text-3xl font-bold text-purple-600"><%= stats.totalWallets || 0 %></p>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-6">
                    <h3 class="text-xl font-bold text-gray-800 mb-4">Recent Users</h3>
                    <p class="text-gray-600">User management coming soon...</p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>